{
  "manifest_version": 2,
  "id": "com.0-hz.image-recompress",
  "version": "0.1.0",
  "name": "Image Recompress",
  "description": "在入站消息进入处理流程前，把图片组件重压缩为更高效的 WebP（可配置 JPEG/PNG）。支持动图转动态 WebP、仅压缩超大图、目标大小循环压缩等模式，用于替代主程序内置的 JPEG 压缩（需关闭 visual.handle_oversized_images）。",
  "author": {
    "name": "kes",
    "url": "https://github.com/yufei-pan"
  },
  "license": "MIT",
  "urls": {
    "repository": "https://github.com/yufei-pan/maibot-image-recompress",
    "homepage": "https://github.com/yufei-pan/maibot-image-recompress",
    "documentation": "https://github.com/yufei-pan/maibot-image-recompress/blob/main/README.md",
    "issues": "https://github.com/yufei-pan/maibot-image-recompress/issues"
  },
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.99.99"
  },
  "sdk": {
    "min_version": "2.5.1",
    "max_version": "2.99.99"
  },
  "dependencies": [
    {
      "type": "python_package",
      "name": "pillow",
      "version_spec": ">=10.0.0"
    }
  ],
  "capabilities": ["config.get"],
  "i18n": {
    "default_locale": "zh-CN"
  }
}
